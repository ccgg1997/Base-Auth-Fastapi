# Token entregado por @BotFather en Telegram.
BOT_TOKEN=

# Clave del proyecto de OpenAI. Nunca se envía al frontend ni a Telegram.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# API de SaludPlus. Desde Docker Desktop se usa el puerto publicado del backend.
API_BASE_URL=http://host.docker.internal:3000
API_USERNAME=
API_PASSWORD=

# IDs numéricos de chats autorizados, separados por coma.
# Ejecuta /start para conocer el ID del chat que debes agregar.
BOT_ALLOWED_CHAT_IDS=

BOT_DASHBOARD_DAYS=30
BOT_PATIENT_LIMIT=100
BOT_MAX_OUTPUT_TOKENS=700
